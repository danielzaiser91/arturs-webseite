AddDefaultCharset UTF-8

# HTML-Seiten nie lange cachen -- Updates sollen sofort bei jedem
# Besucher ankommen, ohne dass jemand einen Hard-Refresh braucht.
<FilesMatch "\.html$">
  Header set Cache-Control "no-cache, must-revalidate"
</FilesMatch>

# Versionierte Assets (per ?v=N in der URL) duerfen dagegen lange
# gecacht werden -- sicher, weil sich die URL bei Aenderungen aendert.
<FilesMatch "\.(css|js|woff2|jpg|jpeg|png|svg|ico)$">
  Header set Cache-Control "public, max-age=2592000"
</FilesMatch>
